# Gradle
.gradle/

# Build outputs — reglas ancladas para evitar conflictos con negaciones.
# IMPORTANTE: composeApp/build/ NO está bloqueado globalmente porque
# composeApp/build/webDemo/ debe ser trackeado (artefactos pre-compilados
# para Cloudflare Pages, que no tiene toolchain Kotlin/WasmJs).
/build/
/server/build/
/shared/build/

# Ignorar todo dentro de composeApp/build/ EXCEPTO webDemo/
/composeApp/build/*
!/composeApp/build/webDemo
/composeApp/build/webDemo/*
!/composeApp/build/webDemo/**

# Kotlin
.kotlin/

# IntelliJ / Android Studio
.idea/
*.iml

# Local config
local.properties

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# Kotlin/JS/WASM caches
node_modules/
.kotlinc/

# Generated distributions
dist/
out/

# Compose Desktop
composeApp/distributions/

# Ktor
server/build/

# Temporary files
tmp/
temp/